# Copy to .env and fill in. All variables are optional except a working RPC.

# Robinhood Chain JSON-RPC endpoint (keyless public RPC; swap for Alchemy/dRPC if heavy).
AEGIS_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Pin the expected chain id so a spoofed/wrong RPC is caught (Robinhood Chain = 4663).
AEGIS_CHAIN_ID=4663

# Blockscout-compatible explorer API (verified-source lookups).
AEGIS_EXPLORER_API=https://robinhoodchain.blockscout.com/api

# Verdict thresholds (points).
# AEGIS_CAUTION_SCORE=25
# AEGIS_NOGO_SCORE=60

# Market-maturity gates. On a young chain thin liquidity is normal, so these let
# it caution instead of blocking. Security signals (honeypot, fee, mint) always
# block regardless. The CLI relaxes these automatically for Robinhood Chain.
# AEGIS_LIQ_DANGER_BELOW=5000
# AEGIS_LIQ_WARN_BELOW=25000
# AEGIS_BLOCK_ON_THIN_LIQUIDITY=true
# AEGIS_BLOCK_ON_HIGH_IMPACT=true

# AI summary via Claude. Set your key and install the `ai` extra.
# ANTHROPIC_API_KEY=sk-ant-...
# AEGIS_AI_ENABLED=true
# AEGIS_AI_MODEL=claude-opus-4-8
