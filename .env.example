# Copy to .env and fill in. All variables are optional except a working RPC.

# Robinhood Chain JSON-RPC endpoint (required for live scans).
KABUTO_RPC_URL=https://rpc.robinhoodchain.example/replace-me

# Pin the expected chain id so a spoofed/wrong RPC is caught (recommended).
# KABUTO_CHAIN_ID=

# Blockscout-compatible explorer API (verified-source lookups).
KABUTO_EXPLORER_API=https://robinhoodchain.blockscout.com/api

# Verdict thresholds (points).
# KABUTO_CAUTION_SCORE=25
# KABUTO_NOGO_SCORE=60

# AI summary via Claude. Set your key and install the `ai` extra.
# ANTHROPIC_API_KEY=sk-ant-...
# KABUTO_AI_ENABLED=true
# KABUTO_AI_MODEL=claude-opus-4-8
