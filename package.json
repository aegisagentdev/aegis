{
  "name": "aegis-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Aegis — a two-way security shield for agentic trading on Robinhood Chain. Prompt-injection firewall on the way in, pre-trade safety scanner on the way out.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
